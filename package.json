{
  "name": "rasan-platform-full",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "install-frontend": "cd frontend && npm install --legacy-peer-deps",
    "build-frontend": "cd frontend && npm run build",
    "build": "npm run install-frontend && npm run build-frontend && rm -rf public/* && cp -r frontend/dist/* public/",
    "start": "node src/server.js"
  },
  "dependencies": {
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "mysql2": "^3.6.0",
    "stripe": "^13.3.0",
    "nodemailer": "^6.9.0",
    "socket.io": "^4.7.0",
    "helmet": "^7.0.0",
    "express-rate-limit": "^7.0.0",
    "joi": "^17.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "eslint": "^8.48.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
