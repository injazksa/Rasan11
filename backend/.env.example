# ============================================
# منصة رَسَن - Rasan Platform
# Backend Environment Configuration
# ============================================

# Server Configuration
NODE_ENV=development
PORT=5000
HOST=localhost

# Database Configuration
DATABASE_URL=mysql://root:password@localhost:3306/rasan
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=rasan

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Apple Pay Configuration
APPLE_PAY_MERCHANT_ID=merchant.com.rasan.app
APPLE_PAY_CERTIFICATE_PATH=./certs/apple_pay.pem

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@rasan.app

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379

# AWS S3 Configuration (Optional)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=rasan-uploads

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# API Keys
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Feature Flags
ENABLE_AUCTIONS=true
ENABLE_MARKETPLACE=true
ENABLE_PRESCRIPTIONS=true
ENABLE_NOTIFICATIONS=true
