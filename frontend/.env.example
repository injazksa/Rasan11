# ============================================
# منصة رَسَن - Rasan Platform
# Frontend Environment Configuration
# ============================================

# API Configuration
VITE_API_URL=http://localhost:5000
VITE_API_TIMEOUT=30000

# Application Configuration
VITE_APP_NAME=Rasan
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=منصة رَسَن - نظام إدارة الخيول الشامل

# Authentication
VITE_AUTH_ENABLED=true
VITE_JWT_STORAGE_KEY=rasan_token

# Stripe Configuration
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_publishable_key

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Feature Flags
VITE_ENABLE_AUCTIONS=true
VITE_ENABLE_MARKETPLACE=true
VITE_ENABLE_PRESCRIPTIONS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_ANALYTICS=true

# Theme Configuration
VITE_THEME_PRIMARY_COLOR=#D4AF37
VITE_THEME_SECONDARY_COLOR=#2C2C2C
VITE_THEME_BACKGROUND_COLOR=#FBFBFB

# Analytics
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_ID=your_analytics_id

# Environment
VITE_ENVIRONMENT=development
